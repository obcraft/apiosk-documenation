        ],
        "operationId": "getAgentMetadata",
        "summary": "Agent metadata",
        "x-mint": {
          "metadata": {
            "title": "Get agent metadata",
            "sidebarTitle": "Metadata"
          }
        },
        "parameters": [
          {
            "name": "api_slug",
            "in": "path",
